pragma solidity ^0.8.22;

import "forge-std/Script.sol";
import "../src/interfaces/IShMonad.sol";
import { IERC20 } from "openzeppelin-contracts/contracts/token/ERC20/IERC20.sol";

contract MonadTestScript is Script {
    function run() external {
        console.log("\n=== MONAD TEST ===\n");

        uint256 userPrivateKey = vm.envUint("USER_PRIVATE_KEY");
        address user = vm.addr(userPrivateKey);
        console.log("===============================");
        console.log("User address:", user);
        console.log("===============================");

        vm.startBroadcast(userPrivateKey);
        uint256 msgValue = 1e16;
        uint256 gasLimit = 1978000;
        address rare = 0x7607a128d6b8447e587660D9565d824804c0EAD7; 
        address payable ATLAS_ADDRESS = payable(0x9958Ab9f64EF51194C5378a336D2A0b0A620D31c);
        

        uint256 userTokenBalanceBefore = _balanceOf(rare, user);

        bytes memory data = hex"";
        (bool success, ) = ATLAS_ADDRESS.call{value: msgValue, gas: gasLimit}(data);
        require(success, "Transaction failed");

        uint256 userTokenBalanceAfter = _balanceOf(rare, user);

        console.log("User RARE balance change:", userTokenBalanceAfter - userTokenBalanceBefore);

        vm.stopBroadcast();
    }

    function _balanceOf(address token, address account) internal view returns (uint256) {
        address NATIVE_TOKEN = address(0);
        if (token == NATIVE_TOKEN) {
            return account.balance;
        } else {
            return IERC20(token).balanceOf(account);
        }
    }
}


